{
  "name": "securavpnclient",
  "version": "1.0.3",
  "description": "SecuraVPN Nexus Client - Premium Desktop Suite",
  "author": "SecuraVPN",
  "homepage": "https://securavpn.nexus",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.securavpn.nexus",
    "productName": "SecuraVPN Nexus",
    "directories": {
      "output": "dist_electron"
    },
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "linux": {
      "maintainer": "SecuraVPN <support@securavpn.nexus>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "keywords": [
    "vpn",
    "nexus",
    "securavpn"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.14.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "sudo-prompt": "^9.2.1"
  }
}